# Google/Serper powers Reddit and Quora discovery without scraping either site.
SERPER_API_KEY=

# Google Cloud API key with YouTube Data API v3 enabled.
YOUTUBE_API_KEY=

# Protects GET /api/cron/scan. Use a long random value in production.
CRON_SECRET=

# Durable Postgres connection for hosted settings and opportunities.
# Neon, Supabase, and other standard hosted Postgres URLs work.
DATABASE_URL=
